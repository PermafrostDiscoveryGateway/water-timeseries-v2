{"metadata": {".zgroup": {"zarr_format": 2}, ".zattrs": {"author": "Ingmar Nitze (Alfred Wegener Institute), Kayla Hardie (Google), Chen Wang (NCSA, U Illinois), Todd Nicholson(NCSA, U Illinois)", "contact": "ingmar.nitze@awi.de", "description": "This datasets provides the monthly area of the dynamic world classes (water, trees, grass, flooded_vegetation, crops, shrub_and_scrub, built, bare, snow_and_ice) for selected lake polygons. The areas were calculated from the Dynamic World V1 dataset through Google Earth Engine. Lake polygons were calculated by Ingmar Nitze through the Permafrost Discovery Gateway Project. \"id_geohash\" is the lake_id, which needs be joined to the accompanying polygon vector dataset"}, "bare/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "bare/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "built/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "built/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "crops/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "crops/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "date/.zattrs": {"units": "days since 2015-07-01", "calendar": "proleptic_gregorian", "_ARRAY_DIMENSIONS": ["date"]}, "date/.zarray": {"shape": [41], "chunks": [41], "dtype": "<i8", "fill_value": null, "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "flooded_vegetation/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "flooded_vegetation/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "grass/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "grass/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "id_geohash/.zattrs": {"_ARRAY_DIMENSIONS": ["id_geohash"]}, "id_geohash/.zarray": {"shape": [5], "chunks": [31210], "dtype": "<U12", "fill_value": null, "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "shrub_and_scrub/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "shrub_and_scrub/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "snow_and_ice/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "snow_and_ice/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "trees/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "trees/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}, "water/.zattrs": {"units": "ha", "_ARRAY_DIMENSIONS": ["id_geohash", "date"]}, "water/.zarray": {"shape": [5, 41], "chunks": [124837, 3], "dtype": "<f8", "fill_value": "NaN", "order": "C", "filters": null, "dimension_separator": ".", "compressor": {"id": "blosc", "cname": "lz4", "clevel": 5, "shuffle": 1, "blocksize": 0}, "zarr_format": 2}}, "zarr_consolidated_format": 1}